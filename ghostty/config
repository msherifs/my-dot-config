font-family = "Maple Mono NF"
font-size = 14

theme = nordfox

adjust-cell-height = 20%
adjust-cursor-height = 20%
shell-integration-features = no-cursor
cursor-style = block
cursor-style-blink = true
window-width = 140
window-height = 37

background-opacity = 0.7
background-blur = 40

keybind = shift+enter=text:\n
